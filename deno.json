{
	"name": "@nlozgachev/pipelined",
	"version": "0.11.0",
	"exports": {
		"./composition": "./src/Composition/index.ts",
		"./core": "./src/Core/index.ts",
		"./types": "./src/Types/index.ts",
		"./utils": "./src/Utils/index.ts"
	},
	"tasks": {
		"test": "deno test",
		"bench": "deno bench src/",
		"build:npm": "deno run -A scripts/build_npm.ts",
		"publish:npm": "deno task build:npm && cd npm && npm publish --access public"
	},
	"exclude": [
		"docs"
	],
	"fmt": {
		"lineWidth": 120,
		"semiColons": true,
		"useTabs": true,
		"exclude": ["*.md"]
	},
	"lint": {
		"rules": {
			"tags": [
				"recommended"
			],
			"exclude": [
				"no-namespace"
			]
		}
	},
	"imports": {
		"@deno/dnt": "jsr:@deno/dnt@^0.42.3",
		"#core/": "./src/Core/",
		"#utils/": "./src/Utils/",
		"#types/": "./src/Types/",
		"#composition/": "./src/Composition/"
	}
}
