{
  "name": "@nlozgachev/pipelined",
  "version": "0.6.4",
  "exports": {
    "./composition": "./src/Composition/index.ts",
    "./core": "./src/Core/index.ts",
    "./types": "./src/Types/index.ts"
  },
  "tasks": {
    "test": "deno test",
    "build:npm": "deno run -A scripts/build_npm.ts",
    "publish:npm": "deno task build:npm && cd npm && npm publish --access public"
  },
  "exclude": [
    "docs"
  ],
  "fmt": {
    "lineWidth": 100,
    "exclude": ["README.md"]
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ],
      "exclude": [
        "no-namespace"
      ]
    }
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3"
  }
}
