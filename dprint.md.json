{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"lineWidth": 100,
	"useTabs": false,
	"indentWidth": 2,
	"excludes": ["dist/", "node_modules/"],
	"markdown": {
		"textWrap": "always",
		"emphasisKind": "asterisks",
		"strongKind": "asterisks"
	},
	"plugins": [
		"https://plugins.dprint.dev/markdown-0.22.1.wasm"
	]
}
