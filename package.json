{
	"name": "@nlozgachev/pipelined",
	"version": "0.37.0",
	"description": "Opinionated functional abstractions for TypeScript",
	"license": "BSD-3-Clause",
	"homepage": "https://pipelined.lozgachev.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nlozgachev/pipelined.git"
	},
	"keywords": [
		"functional",
		"fp",
		"typescript",
		"composition",
		"pipe"
	],
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"engines": {
		"node": ">=24"
	},
	"files": [
		"dist"
	],
	"imports": {
		"#core": "./src/Core/index.ts",
		"#utils": "./src/Utils/index.ts",
		"#types": "./src/Types/index.ts",
		"#composition": "./src/Composition/index.ts",
		"#internal": "./src/internal/index.ts"
	},
	"exports": {
		"./composition": {
			"types": "./dist/composition.d.ts",
			"import": "./dist/composition.mjs",
			"require": "./dist/composition.cjs"
		},
		"./core": {
			"types": "./dist/core.d.ts",
			"import": "./dist/core.mjs",
			"require": "./dist/core.cjs"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.mjs",
			"require": "./dist/utils.cjs"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"import": "./dist/types.mjs",
			"require": "./dist/types.cjs"
		}
	},
	"scripts": {
		"test": "vitest run",
		"bench": "vitest bench",
		"build": "tsup",
		"format": "dprint fmt && dprint fmt --config dprint.md.json \"docs/**/*.md\" \"docs/**/*.mdx\" \"README.md\"",
		"format:check": "dprint check && dprint check --config dprint.md.json \"docs/**/*.md\" \"docs/**/*.mdx\" \"README.md\"",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint src/",
		"publish:npm": "pnpm build && npm publish --access public",
		"release:patch": "bumpp --patch -c -t -p",
		"release:minor": "bumpp --minor -c -t -p",
		"docs:dev": "pnpm --filter pipelined-docs dev",
		"docs:build": "pnpm --filter pipelined-docs build"
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"@vitest/coverage-v8": "4.1.7",
		"bumpp": "11.1.0",
		"dprint": "0.54.0",
		"fast-check": "4.8.0",
		"oxlint": "1.66.0",
		"tsup": "8.5.1",
		"typescript": "6.0.3",
		"vitest": "4.1.7"
	},
	"packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
