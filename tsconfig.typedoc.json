{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"strict": true,
		"lib": [
			"esnext",
			"DOM"
		],
		"types": [
			"node"
		],
		"paths": {
			"#core/*": [
				"./src/Core/*"
			],
			"#data/*": [
				"./src/Data/*"
			],
			"#types/*": [
				"./src/Types/*"
			],
			"#composition/*": [
				"./src/Composition/*"
			]
		}
	},
	"include": [
		"src/**/*.ts"
	],
	"exclude": [
		"src/**/__tests__/**",
		"src/**/__bench__/**"
	]
}
