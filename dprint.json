{
	"$schema": "https://dprint.dev/schemas/v0.json",
	"lineWidth": 120,
	"useTabs": true,
	"indentWidth": 1,
	"typescript": {
		"semiColons": "always",
		"quoteStyle": "preferDouble",
		"trailingCommas": "onlyMultiLine"
	},
	"excludes": ["dist/", "node_modules/", "*.md", "*.mdx"],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.95.15.wasm",
	]
}
